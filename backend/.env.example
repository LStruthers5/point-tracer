STRAVA_CLIENT_ID=your-strava-client-id
STRAVA_CLIENT_SECRET=your-strava-client-secret
STRAVA_REDIRECT_URI=http://127.0.0.1:8000/api/strava/callback
POINTTRACER_FRONTEND_URL=http://localhost:5173
POINTTRACER_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
STRAVA_TOKEN_DB_PATH=backend/.local/strava_tokens.sqlite3
# Random secret you choose when subscribing to Strava webhooks (optional; needed to receive deauth events)
STRAVA_WEBHOOK_VERIFY_TOKEN=your-random-webhook-secret
# Data store for invite-link group sessions + opt-in training corrections.
# Production: set DATABASE_URL to a Postgres connection string (e.g. Railway's
#   ${{Postgres.DATABASE_URL}}) — persists across redeploys, no volume needed.
# Local dev: leave DATABASE_URL unset to use a single local SQLite file.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
# Optional local SQLite path override (only used when DATABASE_URL is unset):
# POINTTRACER_DB_PATH=backend/.local/pointtracer.sqlite3
